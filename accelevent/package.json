{
  "name": "accelevent",
  "version": "1.0.0",
  "description": "Build tooling for Accelevent static assets",
  "license": "MPL-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean:css": "shx rm -rf ./dist/temp/* ./dist/css/*",
    "clean:js": "shx rm -rf ./dist/js/*",
    "clean": "run-p clean:css clean:js",
    "build:css": "NODE_ENV=production node build-css.js",
    "build:js": "node esbuild.config.js --node-env production",
    "build": "run-s clean build:css build:js",
    "watch:css": "NODE_ENV=development node build-css.js && chokidar './src/scss/**/*.scss' -c 'NODE_ENV=development node build-css.js'",
    "watch:js": "node esbuild.config.js --node-env development",
    "dev": "run-p watch:css watch:js"
  },
  "dependencies": {
    "esbuild": "^0.25.2",
    "sass": "^1.86.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.24",
    "chokidar-cli": "^3.0.0",
    "npm-run-all2": "^7.0.2",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "shx": "^0.4.0"
  },
  "packageManager": "yarn@1.22.22"
}
